# Dependencies
node_modules/

# Build output
dist/
build/

# Environment / secrets
.env
.env.*

# Terraform state - never commit
*.tfstate
*.tfstate.*

# Backend config contains your state bucket name/region
terraform/backend.hcl

# Var values may contain personal config (bucket names, domain, etc.)
terraform/*.tfvars

# Terraform working directory
**/.terraform/
**/.terraform.lock.hcl
**/crash.log

# macOS
.DS_Store

# Editor
.vscode/
.idea/
